(version v0.17.0)

(build
 (all_platforms ((action (run dune build -p %{pkg-self:name} -j %{jobs})))))

(depends
 (all_platforms
  (ocaml
   async
   async_ssl
   async_websocket
   core
   ppx_jane
   base64
   cohttp
   cohttp-async
   dune
   uri-sexp)))

