(version v0.17.0)

(build
 (all_platforms ((action (run dune build -p %{pkg-self:name} -j %{jobs})))))

(depends
 (all_platforms
  (ocaml
   core
   ppx_jane
   splittable_random
   typerep
   zarith_stubs_js
   dune
   num
   zarith)))

(source
 (fetch
